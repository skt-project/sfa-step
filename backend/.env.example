# Copy to .env and fill in values. Never commit .env to git.

# BigQuery
BQ_PROJECT=skintific-data-warehouse
BQ_DATASET=sfa_web
# Path to the service account JSON key.
# Needs: BigQuery Data Viewer (project-level) + BigQuery Data Editor (sfa_step dataset) + BigQuery Job User
# Leave empty on Cloud Run — uses Workload Identity automatically.
BQ_SA_KEY_PATH=D:/Claude/bq-step-readwrite.json

# JWT auth
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_random_32_byte_hex
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# CORS — space-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:8080 https://step-prototype.netlify.app
